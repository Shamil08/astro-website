</style>

<script>
  // Draw SVG connection lines with animated dots
  function drawOrchLines() {
    const svg = document.getElementById('orchSvg');
    if (!svg) return;
    
    const wrapper = svg.parentElement;
    if (!wrapper) return;
    
    const rect = wrapper.getBoundingClientRect();
    svg.setAttribute('viewBox', `0 0 ${rect.width} ${rect.height}`);
    svg.innerHTML = '';

    // Create gradient for lines
    const defs = document.createElementNS('http://www.w3.org/2000/svg', 'defs');
    const grad = document.createElementNS('http://www.w3.org/2000/svg', 'linearGradient');
    grad.setAttribute('id', 'orchLineGrad');
    grad.setAttribute('x1', '0%');
    grad.setAttribute('y1', '0%');
    grad.setAttribute('x2', '100%');
    grad.setAttribute('y2', '0%');
    grad.innerHTML = `
      <stop offset="0%" style="stop-color:rgba(139,92,246,0.6);stop-opacity:1" />
      <stop offset="50%" style="stop-color:rgba(79,142,247,0.6);stop-opacity:1" />
      <stop offset="100%" style="stop-color:rgba(139,92,246,0.6);stop-opacity:1" />
    `;
    defs.appendChild(grad);
    svg.appendChild(defs);

    // Helper to get element center
    const getCenter = (id: string) => {
      const el = document.getElementById(id);
      if (!el) return null;
      const elRect = el.getBoundingClientRect();
      const wrapperRect = wrapper.getBoundingClientRect();
      return {
        x: elRect.left + elRect.width / 2 - wrapperRect.left,
        y: elRect.top + elRect.height / 2 - wrapperRect.top
      };
    };

    // Get right edge of element
    const getRightEdge = (id: string) => {
      const el = document.getElementById(id);
      if (!el) return null;
      const elRect = el.getBoundingClientRect();
      const wrapperRect = wrapper.getBoundingClientRect();
      return {
        x: elRect.right - wrapperRect.left,
        y: elRect.top + elRect.height / 2 - wrapperRect.top
      };
    };

    // Get left edge of element
    const getLeftEdge = (id: string) => {
      const el = document.getElementById(id);
      if (!el) return null;
      const elRect = el.getBoundingClientRect();
      const wrapperRect = wrapper.getBoundingClientRect();
      return {
        x: elRect.left - wrapperRect.left,
        y: elRect.top + elRect.height / 2 - wrapperRect.top
      };
    };

    // Add single arrow from Knowledge panel to Platform box
    const knowledgePanel = document.querySelector('.orch-knowledge-panel');
    const platformBox = document.getElementById('orch-platform');
    
    // Helper to get element top edge
    const getTopEdge = (id: string) => {
      const el = document.getElementById(id);
      if (!el) return null;
      const elRect = el.getBoundingClientRect();
      const wrapperRect = wrapper.getBoundingClientRect();
      return {
        x: elRect.left + elRect.width / 2 - wrapperRect.left,
        y: elRect.top - wrapperRect.top
      };
    };

    // Helper to get element bottom edge
    const getBottomEdge = (id: string) => {
      const el = document.getElementById(id);
      if (!el) return null;
      const elRect = el.getBoundingClientRect();
      const wrapperRect = wrapper.getBoundingClientRect();
      return {
        x: elRect.left + elRect.width / 2 - wrapperRect.left,
        y: elRect.bottom - wrapperRect.top
      };
    };

    // Define connections with colors
    const connections = [
      // Channels to Platform
      { from: 'orch-ch-chat', to: 'orch-platform', color: '#8b5cf6', fromEdge: 'right', toEdge: 'left', mainFlow: true },
      { from: 'orch-ch-mail', to: 'orch-platform', color: '#4f8ef7', fromEdge: 'right', toEdge: 'left', mainFlow: true },
      { from: 'orch-ch-voice', to: 'orch-platform', color: '#ec4899', fromEdge: 'right', toEdge: 'left', mainFlow: true },
      // Platform to Systems
      { from: 'orch-platform', to: 'orch-sys-crm', color: '#818cf8', fromEdge: 'right', toEdge: 'left', mainFlow: true },
      { from: 'orch-platform', to: 'orch-sys-sales', color: '#34d399', fromEdge: 'right', toEdge: 'left', mainFlow: true },
      { from: 'orch-platform', to: 'orch-sys-support', color: '#60a5fa', fromEdge: 'right', toEdge: 'left', mainFlow: true },
      { from: 'orch-platform', to: 'orch-sys-analytics', color: '#f472b6', fromEdge: 'right', toEdge: 'left', mainFlow: true }
    ];

    connections.forEach((conn, index) => {
      let start, end;
      
      if (conn.fromEdge === 'right') {
        start = getRightEdge(conn.from);
      } else if (conn.fromEdge === 'top') {
        start = getTopEdge(conn.from);
      } else {
        start = getCenter(conn.from);
      }
      
      if (conn.toEdge === 'left') {
        end = getLeftEdge(conn.to);
      } else if (conn.toEdge === 'bottom') {
        end = getBottomEdge(conn.to);
      } else {
        end = getCenter(conn.to);
      }
      
      if (!start || !end) return;

      // Create curved path
      let d;
      if (conn.fromEdge === 'top' && conn.toEdge === 'bottom') {
        // Vertical connection with curve
        const midY = (start.y + end.y) / 2;
        d = `M ${start.x},${start.y} C ${start.x},${midY} ${end.x},${midY} ${end.x},${end.y}`;
      } else {
        // Horizontal connection
        const midX = (start.x + end.x) / 2;
        // Small 2px gap to prevent stroke overlapping border thickness
        
        let pathStartX = start.x;
        let pathEndX = end.x;
        
        // If it's entering the platform from left
        if (conn.to === 'orch-platform') {
           pathEndX = end.x - 2;
        } 
        // If it's exiting the platform to right
        else if (conn.from === 'orch-platform') {
           pathStartX = start.x + 2;
        }
        
        d = `M ${pathStartX},${start.y} C ${midX},${start.y} ${midX},${end.y} ${pathEndX},${end.y}`;
      }
      
      // Create path
      const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path.setAttribute('d', d);
      path.setAttribute('stroke', conn.color);
      path.setAttribute('stroke-width', '2.5');
      path.setAttribute('stroke-dasharray', '8 4');
      path.setAttribute('fill', 'none');
      path.setAttribute('opacity', '0.9');
      path.style.animation = `dash-flow ${2 + index * 0.2}s linear infinite`;
      svg.appendChild(path);

      // Create animated glowing dot
      const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      circle.setAttribute('r', '4');
      circle.setAttribute('fill', conn.color);
      circle.setAttribute('filter', 'url(#glow)');
      
      // Create glow filter
      if (index === 0) {
        const filter = document.createElementNS('http://www.w3.org/2000/svg', 'filter');
        filter.setAttribute('id', 'glow');
        filter.innerHTML = `
          <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
          <feMerge>
            <feMergeNode in="coloredBlur"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        `;
        defs.appendChild(filter);
      }

      // Animate dot along path
      const animateMotion = document.createElementNS('http://www.w3.org/2000/svg', 'animateMotion');
      animateMotion.setAttribute('dur', `${2.5 + index * 0.3}s`);
      animateMotion.setAttribute('repeatCount', 'indefinite');
      animateMotion.setAttribute('path', d);
      circle.appendChild(animateMotion);
      
      svg.appendChild(circle);
    });

    // Add multiple arrows from Knowledge panel to Platform box
    if (knowledgePanel && platformBox) {
      const knowledgeRect = knowledgePanel.getBoundingClientRect();
      const platformRect = platformBox.getBoundingClientRect();
      const svgRect = svg.getBoundingClientRect();
      
      // Colors for the 4 knowledge streams
      const knowColors = ['#94a3b8', '#fbbf24', '#6ee7b7', '#818cf8'];
      const numLines = knowColors.length;
      
      for (let i = 0; i < numLines; i++) {
        // Distribute start points evenly across the top border of knowledge panel
        // Use a padded width so lines aren't at the extreme edges
        const knowPadding = knowledgeRect.width * 0.2;
        const knowUsableWidth = knowledgeRect.width - (knowPadding * 2);
        const startX = knowledgeRect.left - svgRect.left + knowPadding + (knowUsableWidth * (i / (numLines - 1)));
        
        // Start exactly at the top boundary
        const startY = knowledgeRect.top - svgRect.top;
        
        // Distribute end points evenly across the bottom border of platform box
        const platPadding = platformRect.width * 0.25;
        const platUsableWidth = platformRect.width - (platPadding * 2);
        const endX = platformRect.left - svgRect.left + platPadding + (platUsableWidth * (i / (numLines - 1)));
        
        // End exactly at the bottom boundary
        const endY = platformRect.bottom - svgRect.top;
        
        // Create curved path upward
        const controlY = startY - Math.abs(startY - endY) * 0.45;
        const d = `M ${startX},${startY} C ${startX},${controlY} ${endX},${controlY} ${endX},${endY}`;
        
        const arrowPath = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        arrowPath.setAttribute('d', d);
        arrowPath.setAttribute('stroke', knowColors[i]);
        arrowPath.setAttribute('stroke-width', '2.5');
        arrowPath.setAttribute('stroke-dasharray', '8 4');
        arrowPath.setAttribute('fill', 'none');
        arrowPath.setAttribute('opacity', '0.7');
        arrowPath.style.animation = `dash-flow ${2.5 + i * 0.2}s linear infinite`;
        svg.appendChild(arrowPath);
        
        const arrowDot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        arrowDot.setAttribute('r', '3.5');
        arrowDot.setAttribute('fill', knowColors[i]);
        arrowDot.setAttribute('filter', 'url(#glow)');
        
        const animateMotion = document.createElementNS('http://www.w3.org/2000/svg', 'animateMotion');
        animateMotion.setAttribute('dur', `${3 + i * 0.3}s`);
        animateMotion.setAttribute('repeatCount', 'indefinite');
        animateMotion.setAttribute('path', d);
        arrowDot.appendChild(animateMotion);
        
        svg.appendChild(arrowDot);
      }
    }
  }

  // Add CSS animation for dash flow
  const style = document.createElement('style');
  style.textContent = `
    @keyframes dash-flow {
      from { stroke-dashoffset: 24; }
      to { stroke-dashoffset: 0; }
    }
  `;
  document.head.appendChild(style);

  // Initialize on load and resize
  if (typeof window !== 'undefined') {
    window.addEventListener('load', drawOrchLines);
    window.addEventListener('resize', drawOrchLines);
    // Also draw after a short delay to ensure elements are rendered
    setTimeout(drawOrchLines, 100);
  }
</script>
