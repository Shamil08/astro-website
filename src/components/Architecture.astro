        <path id="arch-rp3" d="M30,0 C30,14 30,28 30,56" fill="none" stroke="rgba(168,85,247,0.5)" stroke-width="1.5" stroke-dasharray="5 5"><animate attributeName="stroke-dashoffset" from="20" to="0" dur="1.4s" repeatCount="indefinite"/></path>
        <circle r="3" fill="#a855f7" filter="url(#arch-glow-p)"><animateMotion dur="1.4s" repeatCount="indefinite" path="M30,0 C30,14 30,28 30,56"/></circle>
        <circle r="3" fill="#ec4899" filter="url(#arch-glow-p)" opacity="0.7"><animateMotion dur="1.4s" begin="0.46s" repeatCount="indefinite" path="M30,0 C30,14 30,28 30,56"/></circle>
        <circle r="3" fill="#a855f7" filter="url(#arch-glow-p)" opacity="0.4"><animateMotion dur="1.4s" begin="0.92s" repeatCount="indefinite" path="M30,0 C30,14 30,28 30,56"/></circle>
