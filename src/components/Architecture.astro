---
// Architecture/Orchestration section - Polished diagram
---

<section class="orchestration-section" id="architecture">
  <div class="orchestration-container reveal-up">
    <!-- Section Header -->
    <div class="orch-header">
      <div class="orch-badge">
        <span class="orch-badge-dot"></span>
        Platform Architecture
      </div>
      <h2 class="orch-title">
        How RYX AI Orchestrates<br>
        <span class="orch-title-gradient">Customer Communication</span>
      </h2>
    </div>

    <!-- Main Diagram -->
    <div class="orch-diagram-wrapper">
      <svg class="orch-svg-overlay" id="orchSvg"></svg>

      <div class="orch-top-row">
        <!-- LEFT: Communication Channels -->
        <div class="orch-panel orch-panel-left">
          <div class="orch-panel-title">Communication Channels</div>
          <div class="orch-channel-list">
            <div class="orch-channel-item" id="orch-ch-chat">
              <div class="orch-ch-icon" style="background:linear-gradient(135deg,#1e3a8a,#3b82f6)">
                <svg width="19" height="19" viewBox="0 0 24 24" fill="none">
                  <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" fill="white" opacity="0.9"/>
                </svg>
              </div>
              Chat
            </div>
            <div class="orch-channel-item" id="orch-ch-mail">
              <div class="orch-ch-icon" style="background:linear-gradient(135deg,#134e4a,#0d9488)">
                <svg width="19" height="19" viewBox="0 0 24 24" fill="none">
                  <rect x="2" y="4" width="20" height="16" rx="2" stroke="white" stroke-width="1.6"/>
                  <polyline points="2,4 12,13 22,4" stroke="white" stroke-width="1.6" fill="none"/>
                </svg>
              </div>
              Mail
            </div>
            <div class="orch-channel-item" id="orch-ch-voice">
              <div class="orch-ch-icon" style="background:linear-gradient(135deg,#7c2d12,#f97316)">
                <svg width="19" height="19" viewBox="0 0 24 24" fill="none">
                  <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.68A2 2 0 012 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" fill="white" opacity="0.9"/>
                </svg>
              </div>
              Voice
            </div>
          </div>
        </div>

        <!-- CENTER: Platform -->
        <div class="orch-center-col">
          <div class="orch-platform-box" id="orch-platform">
            <div class="orch-platform-header">
              <svg class="orch-platform-logo" viewBox="0 0 28 28" fill="none">
                <defs>
                  <linearGradient id="orchLg1" x1="0" y1="0" x2="28" y2="28" gradientUnits="userSpaceOnUse">
                    <stop offset="0%" stop-color="#4f8ef7"/>
                    <stop offset="100%" stop-color="#7b6ef6"/>
                  </linearGradient>
                </defs>
                <polygon points="14,1.5 25,8 25,20 14,26.5 3,20 3,8" fill="rgba(79,142,247,0.12)" stroke="url(#orchLg1)" stroke-width="1.4"/>
                <circle cx="14" cy="14" r="4.5" fill="none" stroke="url(#orchLg1)" stroke-width="1.2"/>
                <circle cx="14" cy="14" r="2" fill="#4f8ef7"/>
                <line x1="14" y1="3" x2="14" y2="9.5" stroke="#4f8ef7" stroke-width="1" opacity="0.5"/>
                <line x1="14" y1="18.5" x2="14" y2="25" stroke="#4f8ef7" stroke-width="1" opacity="0.5"/>
                <line x1="4.5" y1="9" x2="9.5" y2="12" stroke="#7b6ef6" stroke-width="1" opacity="0.5"/>
                <line x1="18.5" y1="16" x2="23.5" y2="19" stroke="#7b6ef6" stroke-width="1" opacity="0.5"/>
                <line x1="4.5" y1="19" x2="9.5" y2="16" stroke="#7b6ef6" stroke-width="1" opacity="0.5"/>
                <line x1="18.5" y1="12" x2="23.5" y2="9" stroke="#7b6ef6" stroke-width="1" opacity="0.5"/>
              </svg>
              <span class="orch-platform-label">RYX AI Platform</span>
            </div>

            <div class="orch-module" id="orch-mod-ai">
              <div class="orch-mod-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <path d="M12 2L2 7l10 5 10-5-10-5z" fill="white" opacity="0.85"/>
                  <path d="M2 17l10 5 10-5M2 12l10 5 10-5" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </div>
              <div class="orch-mod-text">
                <div class="orch-mod-name">AI Orchestration</div>
                <div class="orch-mod-sub">& Workflow Automation</div>
              </div>
            </div>

            <div class="orch-module" id="orch-mod-kb">
              <div class="orch-mod-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <ellipse cx="12" cy="5" rx="9" ry="3" stroke="white" stroke-width="1.5"/>
                  <path d="M3 5v5c0 1.66 4.03 3 9 3s9-1.34 9-3V5" stroke="white" stroke-width="1.5"/>
                  <path d="M3 10v5c0 1.66 4.03 3 9 3s9-1.34 9-3v-5" stroke="white" stroke-width="1.5"/>
                </svg>
              </div>
              <div class="orch-mod-text">
                <div class="orch-mod-name">Knowledge Lakebase</div>
                <div class="orch-mod-sub">& Routing Engine</div>
              </div>
            </div>

            <div class="orch-module" id="orch-mod-safe">
              <div class="orch-mod-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" fill="rgba(255,255,255,0.15)" stroke="white" stroke-width="1.5"/>
                  <polyline points="9,12 11,14 15,10" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="orch-mod-text">
                <div class="orch-mod-name">Safety & Guardrails</div>
              </div>
            </div>
          </div>
        </div>

        <!-- RIGHT: Business Systems -->
        <div class="orch-panel orch-panel-right">
          <div class="orch-section-sub">
            <svg width="12" height="12" viewBox="0 0 12 12">
              <circle cx="6" cy="6" r="5" fill="#f97316"/>
              <circle cx="6" cy="6" r="2.5" fill="#fed7aa"/>
            </svg>
            Business Systems
          </div>
          <div class="orch-sys-list">
            <div class="orch-sys-item" id="orch-sys-crm">
              <div class="orch-sys-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                  <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="#818cf8" stroke-width="1.8" stroke-linecap="round"/>
                  <circle cx="12" cy="7" r="4" stroke="#818cf8" stroke-width="1.8"/>
                </svg>
              </div>
              CRM
            </div>
            <div class="orch-sys-item" id="orch-sys-sales">
              <div class="orch-sys-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                  <polyline points="22,7 13.5,15.5 8.5,10.5 2,17" stroke="#34d399" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  <polyline points="16,7 22,7 22,13" stroke="#34d399" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
              </div>
              Sales
            </div>
            <div class="orch-sys-item" id="orch-sys-support">
              <div class="orch-sys-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                  <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke="#60a5fa" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              Support
            </div>
            <div class="orch-sys-item" id="orch-sys-analytics">
              <div class="orch-sys-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                  <rect x="2" y="14" width="4" height="8" rx="1" fill="#f472b6" opacity="0.85"/>
                  <rect x="9" y="9" width="4" height="13" rx="1" fill="#f472b6"/>
                  <rect x="16" y="4" width="4" height="18" rx="1" fill="#f472b6" opacity="0.85"/>
                </svg>
              </div>
              Analytics
            </div>
          </div>
        </div>
      </div>

      <!-- BOTTOM: Knowledge Sources -->
      <div class="orch-bottom-row">
        <div class="orch-knowledge-panel">
          <div class="orch-panel-title" style="text-align: center; width: 100%; margin-bottom: 20px;">Connected Knowledge Sources</div>
          <div class="orch-knowledge-inner">
            <div class="orch-know-left">
              <div class="orch-know-list">
                <div class="orch-sys-item">
                  <div class="orch-sys-icon">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                      <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke="#94a3b8" stroke-width="1.8"/>
                      <polyline points="14,2 14,8 20,8" stroke="#94a3b8" stroke-width="1.8" stroke-linecap="round"/>
                      <line x1="8" y1="13" x2="16" y2="13" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round"/>
                      <line x1="8" y1="17" x2="13" y2="17" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                  </div>
                  Internal Docs
                </div>
                <div class="orch-sys-item">
                  <div class="orch-sys-icon">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                      <circle cx="12" cy="12" r="10" stroke="#fbbf24" stroke-width="1.8"/>
                      <path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3" stroke="#fbbf24" stroke-width="1.8" stroke-linecap="round"/>
                      <circle cx="12" cy="17" r="1" fill="#fbbf24"/>
                    </svg>
                  </div>
                  Product FAQs
                </div>
                <div class="orch-sys-item">
                  <div class="orch-sys-icon">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                      <path d="M9 11l3 3L22 4" stroke="#6ee7b7" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" stroke="#6ee7b7" stroke-width="1.8" stroke-linecap="round"/>
                    </svg>
                  </div>
                  Policies &amp; Guides
                </div>
              </div>
            </div>

            <div class="orch-bottom-divider"></div>

            <div class="orch-know-right">
              <div class="orch-avatar-group">
                <!-- Support Agents -->
                <div class="orch-avatar-item">
                  <div class="orch-avatar-ring">
                    <div class="orch-avatar-inner">
                      <img src="/avatars/avatar_support_animated_1773161829369.png" alt="Support Agent" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;">
                    </div>
                  </div>
                  <div class="orch-avatar-label">Support<br>Agents</div>
                </div>

                <!-- Sales Teams -->
                <div class="orch-avatar-item">
                  <div class="orch-avatar-ring">
                    <div class="orch-avatar-inner">
                      <img src="/avatars/avatar_sales_animated_1773161851992.png" alt="Sales Professional" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;">
                    </div>
                  </div>
                  <div class="orch-avatar-label">Sales<br>Teams</div>
                </div>

                <!-- Ops Experts -->
                <div class="orch-avatar-item">
                  <div class="orch-avatar-ring">
                    <div class="orch-avatar-inner">
                      <img src="/avatars/avatar_ops_animated_1773161876519.png" alt="Ops Expert" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;">
                    </div>
                  </div>
                  <div class="orch-avatar-label">Ops<br>Experts</div>
                </div>

                <!-- Customer Success -->
                <div class="orch-avatar-item">
                  <div class="orch-avatar-ring">
                    <div class="orch-avatar-inner">
                      <img src="/avatars/avatar_cs_animated_1773161904547.png" alt="Customer Success" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;">
                    </div>
                  </div>
                  <div class="orch-avatar-label">Customer<br>Success</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       MOBILE LAYOUT (shown only on ≤820px)
  ═══════════════════════════════════════════ -->
  <div class="arch-mobile">

    <div class="arch-m-pill">
      <span class="arch-pill-dot"></span>
      Platform Architecture
    </div>
    <h2 class="arch-m-title">
      How RYX AI Orchestrates<br>
      <span class="arch-title-gradient">Customer Communication</span>
    </h2>

    <!-- 1. Channels -->
    <div class="arch-m-card">
      <div class="arch-m-label">Communication Channels</div>
      <div class="arch-m-list">
        <div class="arch-m-item">
          <div class="arch-m-icon" style="background:linear-gradient(135deg,#1e3a8a,#3b82f6)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" fill="white" opacity="0.9"/></svg></div>
          Chat
        </div>
        <div class="arch-m-item">
          <div class="arch-m-icon" style="background:linear-gradient(135deg,#134e4a,#0d9488)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="2" y="4" width="20" height="16" rx="2" stroke="white" stroke-width="1.6"/><polyline points="2,4 12,13 22,4" stroke="white" stroke-width="1.6" fill="none"/></svg></div>
          Mail
        </div>
        <div class="arch-m-item">
          <div class="arch-m-icon" style="background:linear-gradient(135deg,#7c2d12,#f97316)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.68A2 2 0 012 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" fill="white" opacity="0.9"/></svg></div>
          Voice
        </div>
      </div>
    </div>

    <!-- Rope connector 1 (blue) -->
    <div class="arch-rope">
      <svg viewBox="0 0 60 56" xmlns="http://www.w3.org/2000/svg">
        <defs><filter id="arch-glow-b"><feGaussianBlur stdDeviation="1.5" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter></defs>
        <path id="arch-rp1" d="M30,0 C30,14 30,28 30,56" fill="none" stroke="rgba(79,142,247,0.5)" stroke-width="1.5" stroke-dasharray="5 5"><animate attributeName="stroke-dashoffset" from="20" to="0" dur="1.4s" repeatCount="indefinite"/></path>
        <circle r="3" fill="#4f8ef7" filter="url(#arch-glow-b)"><animateMotion dur="1.4s" repeatCount="indefinite" path="M30,0 C30,14 30,28 30,56"/></circle>
        <circle r="3" fill="#4f8ef7" filter="url(#arch-glow-b)" opacity="0.7"><animateMotion dur="1.4s" begin="0.46s" repeatCount="indefinite" path="M30,0 C30,14 30,28 30,56"/></circle>
        <circle r="3" fill="#4f8ef7" filter="url(#arch-glow-b)" opacity="0.4"><animateMotion dur="1.4s" begin="0.92s" repeatCount="indefinite" path="M30,0 C30,14 30,28 30,56"/></circle>
      </svg>
    </div>

    <!-- 2. Platform -->
    <div class="arch-m-platform">
      <div class="arch-m-platform-header">
        <svg width="24" height="24" viewBox="0 0 28 28" fill="none" style="animation:arch-spin 10s linear infinite">
          <defs><linearGradient id="arch-mlg" x1="0" y1="0" x2="28" y2="28" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#4f8ef7"/><stop offset="100%" stop-color="#7b6ef6"/></linearGradient></defs>
          <polygon points="14,1.5 25,8 25,20 14,26.5 3,20 3,8" fill="rgba(79,142,247,0.12)" stroke="url(#arch-mlg)" stroke-width="1.4"/>
          <circle cx="14" cy="14" r="4" fill="none" stroke="url(#arch-mlg)" stroke-width="1.2"/>
          <circle cx="14" cy="14" r="2" fill="#4f8ef7"/>
        </svg>
        <span class="arch-m-platform-label">RYX AI Platform</span>
      </div>
      <div class="arch-m-module">
        <div class="arch-m-mod-icon"><svg width="17" height="17" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5z" fill="white" opacity="0.85"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5" stroke="white" stroke-width="1.5" stroke-linecap="round"/></svg></div>
        <div><div class="arch-m-mod-name">AI Orchestration</div><div class="arch-m-mod-sub">&amp; Workflow Automation</div></div>
      </div>
      <div class="arch-m-module">
        <div class="arch-m-mod-icon"><svg width="17" height="17" viewBox="0 0 24 24" fill="none"><ellipse cx="12" cy="5" rx="9" ry="3" stroke="white" stroke-width="1.5"/><path d="M3 5v5c0 1.66 4.03 3 9 3s9-1.34 9-3V5" stroke="white" stroke-width="1.5"/><path d="M3 10v5c0 1.66 4.03 3 9 3s9-1.34 9-3v-5" stroke="white" stroke-width="1.5"/></svg></div>
        <div><div class="arch-m-mod-name">Knowledge Lakebase</div><div class="arch-m-mod-sub">&amp; Routing Engine</div></div>
      </div>
      <div class="arch-m-module" style="margin-bottom:0">
        <div class="arch-m-mod-icon"><svg width="17" height="17" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" fill="rgba(255,255,255,0.15)" stroke="white" stroke-width="1.5"/><polyline points="9,12 11,14 15,10" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        <div><div class="arch-m-mod-name">Safety &amp; Guardrails</div></div>
      </div>
    </div>

    <!-- Rope connector 2 (cyan) -->
    <div class="arch-rope">
      <svg viewBox="0 0 60 56" xmlns="http://www.w3.org/2000/svg">
        <defs><filter id="arch-glow-c"><feGaussianBlur stdDeviation="1.5" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter></defs>
        <path id="arch-rp2" d="M30,0 C30,14 30,28 30,56" fill="none" stroke="rgba(6,182,212,0.5)" stroke-width="1.5" stroke-dasharray="5 5"><animate attributeName="stroke-dashoffset" from="20" to="0" dur="1.4s" repeatCount="indefinite"/></path>
        <circle r="3" fill="#06b6d4" filter="url(#arch-glow-c)"><animateMotion dur="1.4s" repeatCount="indefinite" path="M30,0 C30,14 30,28 30,56"/></circle>
        <circle r="3" fill="#06b6d4" filter="url(#arch-glow-c)" opacity="0.7"><animateMotion dur="1.4s" begin="0.46s" repeatCount="indefinite" path="M30,0 C30,14 30,28 30,56"/></circle>
        <circle r="3" fill="#06b6d4" filter="url(#arch-glow-c)" opacity="0.4"><animateMotion dur="1.4s" begin="0.92s" repeatCount="indefinite" path="M30,0 C30,14 30,28 30,56"/></circle>
      </svg>
    </div>

    <!-- 3. Knowledge Sources -->
    <div class="arch-m-card">
      <div class="arch-m-label">Connected Knowledge Sources</div>
      <div class="arch-m-list">
        <div class="arch-m-item"><div class="arch-m-icon-sm"><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke="#94a3b8" stroke-width="1.8"/><polyline points="14,2 14,8 20,8" stroke="#94a3b8" stroke-width="1.8" stroke-linecap="round"/></svg></div>Internal Docs</div>
        <div class="arch-m-item"><div class="arch-m-icon-sm"><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#fbbf24" stroke-width="1.8"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3" stroke="#fbbf24" stroke-width="1.8" stroke-linecap="round"/><circle cx="12" cy="17" r="1" fill="#fbbf24"/></svg></div>Product FAQs</div>
        <div class="arch-m-item"><div class="arch-m-icon-sm"><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M9 11l3 3L22 4" stroke="#6ee7b7" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" stroke="#6ee7b7" stroke-width="1.8" stroke-linecap="round"/></svg></div>Policies &amp; Guides</div>
      </div>
      <div class="arch-m-divider"></div>
      <!-- Avatars -->
      <div class="arch-m-avatars">
        <div class="arch-m-av-item">
          <div class="arch-m-av-ring"><div class="arch-m-av-inner"><img src="/avatars/avatar_support_animated_1773161829369.png" alt="Support Agent" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;"></div></div>
          <span class="arch-m-av-label">Support<br>Agents</span>
        </div>
        <div class="arch-m-av-item">
          <div class="arch-m-av-ring"><div class="arch-m-av-inner"><img src="/avatars/avatar_sales_animated_1773161851992.png" alt="Sales Teams" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;"></div></div>
          <span class="arch-m-av-label">Sales<br>Teams</span>
        </div>
        <div class="arch-m-av-item">
          <div class="arch-m-av-ring"><div class="arch-m-av-inner"><img src="/avatars/avatar_ops_animated_1773161876519.png" alt="Ops Experts" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;"></div></div>
          <span class="arch-m-av-label">Ops<br>Experts</span>
        </div>
        <div class="arch-m-av-item">
