// Footer component - Modern SaaS layout
---

<!-- CTA Card Section (above footer) -->
<section class="footer-cta-section">
  <div class="footer-cta-container">
    <div class="footer-cta-card reveal-up">
      <div class="footer-cta-badge">Now accepting early access</div>
      <h2 class="footer-cta-heading">Ready to build communication<br/>infrastructure that actually works?</h2>
      <p class="footer-cta-description">Join the engineering teams building the most reliable communication systems in their industry — powered by RYX AI.</p>
      <a href="#contact" class="footer-cta-button">Request access</a>
      <p class="footer-cta-note">No spam. No sales calls. Just early access to the platform.</p>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="footer">
  <div class="footer-container">
    <!-- Main Footer Content -->
    <div class="footer-main">
      <!-- Left Side: Brand -->
      <div class="footer-brand">
        <div class="footer-logo">
          <img src="/logo/logo.png" alt="RYX AI Logo" class="footer-logo-icon" />
          <span class="footer-logo-text">RYX AI</span>
        </div>
        <p class="footer-brand-description">Production-grade communication infrastructure for the AI era.</p>
      </div>

      <!-- Right Side: Link Columns -->
      <div class="footer-links-grid">
        <!-- Column 1: Product -->
        <div class="footer-col">
          <h4 class="footer-col-title">Product</h4>
          <ul class="footer-links">
            <li><a href="#platform">Platform</a></li>
            <li><a href="#routing">Routing Engine</a></li>
            <li><a href="#observability">Observability</a></li>
            <li><a href="#pricing">Pricing</a></li>
          </ul>
        </div>

        <!-- Column 2: Resources -->
        <div class="footer-col">
          <h4 class="footer-col-title">Resources</h4>
          <ul class="footer-links">
            <li><a href="#docs">Documentation</a></li>
            <li><a href="#api">API Reference</a></li>
            <li><a href="#cases">Case Studies</a></li>
            <li><a href="#blog">Blog</a></li>
          </ul>
        </div>

        <!-- Column 3: Company -->
        <div class="footer-col">
          <h4 class="footer-col-title">Company</h4>
          <ul class="footer-links">
            <li><a href="#about">About</a></li>
            <li><a href="#careers">Careers</a></li>
            <li><a href="#security">Security</a></li>
            <li><a href="#contact">Contact</a></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Footer Bottom Bar -->
    <div class="footer-bottom">
      <p class="footer-copyright">&copy; 2026 RYX AI. All rights reserved.</p>
      <div class="footer-legal">
        <a href="#terms">Terms of Service</a>
        <a href="#privacy">Privacy Policy</a>
      </div>
    </div>
  </div>
</footer>
