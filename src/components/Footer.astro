      <!-- Right Side: Link Columns -->
      <div class="footer-links-grid">
        <!-- Column 1: Solutions -->
        <div class="footer-col">
          <h4 class="footer-col-title">Solutions</h4>
          <ul class="footer-links">
            <li><a href="/?industry=financial#solutions" data-select-industry="financial">Finance</a></li>
            <li><a href="/?industry=healthcare#solutions" data-select-industry="healthcare">Healthcare</a></li>
            <li><a href="/?industry=ecommerce#solutions" data-select-industry="ecommerce">E-commerce</a></li>
            <li><a href="/?industry=government#solutions" data-select-industry="government">Government</a></li>
            <li><a href="/?industry=travel#solutions" data-select-industry="travel">Travel &amp; Logistics</a></li>
            <li><a href="/?industry=education#solutions" data-select-industry="education">Education</a></li>
            <li><a href="/?industry=retail#solutions" data-select-industry="retail">Retail</a></li>
            <li><a href="/?industry=insurance#solutions" data-select-industry="insurance">Insurance</a></li>
            <li><a href="/?industry=realestate#solutions" data-select-industry="realestate">Real estate</a></li>
          </ul>
        </div>


        <div class="footer-col">
          <h4 class="footer-col-title">Product</h4>
          <ul class="footer-links">
            <li><a href="/platform">Platform</a></li>
            <li><a href="/#architecture">Platform architecture</a></li>
            <li><a href="/#how">Platform workflow</a></li>
          </ul>
        </div>

        <!-- Column 3: Use Case -->
        <div class="footer-col">
          <h4 class="footer-col-title">Use Case</h4>
          <ul class="footer-links">
            <li><a href="/?case=sales#use-cases" data-select-case="sales">Sales outreach</a></li>
            <li><a href="/?case=support#use-cases" data-select-case="support">Customer Support</a></li>
            <li><a href="/?case=leads#use-cases" data-select-case="leads">Lead generation</a></li>
            <li><a href="/?case=followup#use-cases" data-select-case="followup">Sales followup</a></li>
            <li><a href="/?case=hr#use-cases" data-select-case="hr">HR &amp; Onboarding</a></li>
          </ul>
        </div>

        <!-- Column 4: Quick Links -->
        <div class="footer-col">
          <h4 class="footer-col-title">Quick Links</h4>
          <ul class="footer-links">
            <li><a href="/#pricing">Pricing</a></li>
            <li><a href="/privacy">Privacy Policy</a></li>
            <li><a href="/terms">Terms and Conditions</a></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Footer Bottom Bar -->
    <div class="footer-bottom" style="justify-content: center;">
      <p class="footer-copyright" style="text-align: center;">&copy; 2026 RYX AI. All rights reserved.</p>
    </div>
  </div>
</footer>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const isHome = window.location.pathname === '/';

    // Handle industry (Solutions) links
    document.querySelectorAll('[data-select-industry]').forEach(function(link) {
      link.addEventListener('click', function(e) {
        if (isHome && typeof window.selectIndustry === 'function') {
          e.preventDefault();
          const industry = link.getAttribute('data-select-industry');
          window.selectIndustry(industry);
          const section = document.getElementById('solutions');
          if (section) section.scrollIntoView({ behavior: 'smooth' });
        }
        // else: let the browser navigate normally with the href
      });
    });

    // Handle use-case links
    document.querySelectorAll('[data-select-case]').forEach(function(link) {
      link.addEventListener('click', function(e) {
        if (isHome) {
          e.preventDefault();
          const caseKey = link.getAttribute('data-select-case');
          const targetTab = document.querySelector(`.uc-tab[data-case="${caseKey}"]`);
          if (targetTab) {
            document.querySelectorAll('.uc-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.uc-case').forEach(c => c.classList.remove('active'));
            targetTab.classList.add('active');
            const content = document.querySelector(`[data-case-content="${caseKey}"]`);
            if (content) content.classList.add('active');
            const section = document.getElementById('use-cases');
            if (section) section.scrollIntoView({ behavior: 'smooth' });
          }
        }
      });
    });
  });
</script>
