            <a href="mailto:hello@ryxai.in" style="color: var(--muted-2); transition: color 0.2s; display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='var(--muted-2)'">
