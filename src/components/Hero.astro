---
// Hero section component
---

<section class="hero-section">
  <div class="hero-content reveal">
    <div class="badge">
      <span class="badge-spark">&#10022;</span>
      <span class="badge-text">Production-Grade Communication Automation</span>
    </div>
    <h1 class="hero-title">
      <span class="hero-title-line1">Communication Infrastructure</span>
      <span class="gradient-text">Powered by Intelligence.</span>
    </h1>
    <p class="hero-subtitle">
      We build production-grade communication systems that automate
      structured, high-volume interactions safely and predictably.
    </p>
    <div class="hero-cta-group">
      <button data-modal-trigger="book-meeting" class="btn-hero-primary">Book a meeting</button>
      <a href="#use-cases" class="btn-hero-outline">View use cases</a>
    </div>
    <!--
    <div class="trust-badges">
      <div class="trust-badge"><span class="trust-icon">&#9675;</span> SOC 2 compliant</div>
      <div class="trust-badge"><span class="trust-icon">&#9889;</span> 99.99% uptime SLA</div>
      <div class="trust-badge"><span class="trust-icon">&#9889;</span> Sub-100ms latency</div>
    </div>
    -->
  </div>
</section>
